# ─── Cerebras (the only external inference API memchro calls) ────────────────
CEREBRAS_API_KEY=csk_...
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_MODEL=qwen-3-235b-a22b-instruct-2507

# ─── Persistent memory store: Neon Postgres + pgvector ───────────────────────
# Connection string from your Neon project. Must point at a DB with the
# `vector` extension available (pre-installed on Neon).
# After setting this, run: npx prisma db push && node scripts/init-db.mjs
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# ─── Magic-link auth via Gmail SMTP ───────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=you@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx   # Gmail *app password*, not your account password
SMTP_FROM=you@gmail.com

# Random string used to sign magic-link + session JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=replace-me

# Public URL — used to build the magic-link URL in the email.
# On Vercel this is auto-derived from VERCEL_URL if you leave it blank.
NEXT_PUBLIC_APP_URL=http://localhost:3000
