# ─── Cerebras (the only external API memchro calls) ──────────────────────────
# Create a key at https://inference-docs.cerebras.ai/
CEREBRAS_API_KEY=csk_...
# Defaults to OpenAI-compatible Cerebras endpoint.
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
# Model used for both chat and Mem0-style fact extraction.
CEREBRAS_MODEL=gpt-oss-120b

# ─── Postgres with pgvector (acts as our ChromaDB, serverless-native) ─────────
# Vercel Postgres / Neon / Supabase — anything speaking Postgres + pgvector.
POSTGRES_URL=postgres://user:pass@host/db?sslmode=require

# ─── Magic-link auth (Gmail SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=you@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx   # Gmail *app password*, not your account password
SMTP_FROM=you@gmail.com

# Random string used to sign magic-link + session JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=replace-me

# Public URL — used to build the magic-link URL in the email.
# On Vercel this is auto-derived from VERCEL_URL if you leave it blank.
NEXT_PUBLIC_APP_URL=http://localhost:3000
